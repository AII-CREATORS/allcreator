
window.AImageAttrItems = function() 
{
    const labelStyle = { width: '30%', height: '100%', textAlign: 'right', marginRight: '5px' },
        viewStyle = { width: '100%', height: '25px', padding: '2px', whiteSpace: 'nowrap' }

    const attrItems = 
    {
        'Data': 
        {
            name: 'AView',
            style: { width: '100%', height: 'auto', padding: '2px' },
            children:
            [
                {
                    name: 'AView',
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Src',
                            style: labelStyle,
                        },
                        {
                            name: 'ATextField',
                            id: "Image",
                            group: 'SET_VALUE',
                            event: 'change',
                            listener: 'onTextValueChange',
                            style: { width: '50%', height: '100%', marginRight: '2px' }
                        },
                        {
                            name: 'AButton',
                            text: '...',
                            event: 'click',
                            listener: 'onImagePickerClick',
                            style: { width: '25px', height: '100%' }
                        }
                    ]
                },

                {
                    name: 'AView',
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Alt',
                            style: labelStyle,
                        },
                        {
                            name: 'ATextField',
                            id: "alt",
                            group: 'ATTR_VALUE',
                            event: 'change',
                            listener: 'onTextValueChange',
                            style: { width: '60%', height: '100%' }
                        }
                    ]
                },

            ]
        },    
    }

    return attrItems

}

