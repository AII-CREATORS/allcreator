                            listener: 'onNumberValueChange',
                            style: { width: '60%', height: '100%' }
                        }
                    ]
                },

                {
                    name: 'AView',
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Min',
                            style: labelStyle,
                        },
                        {
                            name: 'ATextField',
                            id: "min",
                            group: 'ATTR_VALUE',
                            type: 'number',
                            event: 'change',
                            listener: 'onNumberValueChange',
                            style: { width: '60%', height: '100%' }
                        }
                    ]
                },

                {
                    name: 'AView',
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Max',
                            style: labelStyle,
                        },
                        {
                            name: 'ATextField',
                            id: "max",
                            group: 'ATTR_VALUE',
                            type: 'number',
