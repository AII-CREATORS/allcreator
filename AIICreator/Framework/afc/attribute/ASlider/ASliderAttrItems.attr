            children:
            [
                {
                    name: 'AView', 
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Value',
                            style: labelStyle,
                        },
                        {
                            name: 'ATextField',
                            id: "value",
                            group: 'ATTR_VALUE',
                            type: 'number',
