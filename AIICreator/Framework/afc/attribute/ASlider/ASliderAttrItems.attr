                },

                {
                    name: 'AView',
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Step',
                            style: labelStyle,
                        },
                        {
                            name: 'ATextField',
                            id: "step",
                            group: 'ATTR_VALUE',
