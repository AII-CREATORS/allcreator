            children:
            [
                {
                    name: 'AView', 
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Direction',
                            style: labelStyle,
                        },
                        {
                            name: 'ASelectBox',
                            id: "flex-direction",
                            group: 'CSS_VALUE',
                            event: 'change',
                            listener: 'onSelectValueChange',
                            style: { width: '60%', height: '100%' },
                            items : [ ['row','row'], ['row-reverse','row-reverse'], ['column','column'], ['column-reverse','column-reverse'] ]
                        }
                    ]
                },

                {
