                            id: "flex-wrap",
                            group: 'CSS_VALUE',
                            event: 'change',
                            listener: 'onSelectValueChange',
                            style: { width: '60%', height: '100%' },
                            items : [ ['nowrap','nowrap'], ['wrap','wrap'], ['wrap-reverse','wrap-reverse'] ]
                        }
                    ]
                },
                {
                    name: 'AView', 
                    style: viewStyle,
                    children:
                    [
                        {
                            name: 'ALabel',
                            text: 'Justify Content',
                            style: labelStyle,
                        },
                        {
                            name: 'ASelectBox',
                            id: "justify-content",
                            group: 'CSS_VALUE',
                            event: 'change',
                            listener: 'onSelectValueChange',
                            style: { width: '60%', height: '100%' },
                            items : [ ['flex-start','flex-start'], ['center','center'], ['flex-end','flex-end'],['space-between','space-between'],['space-around','space-around'],['space-evenly','space-evenly'] ]
                        }
                    ]
                },

                {
                    name: 'AView',
                    style: viewStyle,
                    children:
                    [
                        {
